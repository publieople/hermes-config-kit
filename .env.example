# Hermes Config Kit — Environment Variables
# Copy this file to ~/.hermes/.env and fill in your values

# ── Primary Model ──────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── TTS (MiniMax) ──────────────────────────────────
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_CN_API_KEY=your-minimax-cn-api-key

# ── Memory (Mem0) ──────────────────────────────────
MEM0_API_KEY=your-mem0-api-key

# ── Optional: OpenRouter ───────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional: Google Gemini (auxiliary tasks) ──────
# GOOGLE_API_KEY=...

# ── Optional: X/Twitter API ────────────────────────
# X_BEARER_TOKEN=...

# ── Optional: Anthropic ────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude Code ──────────────────────────
# CLAUDE_CODE_API_KEY=...

# ── Proxy (if behind a firewall) ───────────────────
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890

# ── Feishu / Lark ──────────────────────────────────
# FEISHU_APP_ID=...
# FEISHU_APP_SECRET=...
